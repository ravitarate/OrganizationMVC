@model IEnumerable<OrganizationMVC.Models.User>

@foreach (var item in Model) {
    <tr id="row-@item.UserId">
        <td>@Html.DisplayFor(modelItem => item.UserName)</td>
        <td>@Html.DisplayFor(modelItem => item.Email)</td>
        <td>@Html.DisplayFor(modelItem => item.Department.DepartmentName)</td>
        <td>
            @if (item.UserDocuments != null && item.UserDocuments.Any())
            {
                foreach (var doc in item.UserDocuments)
                {
                    @Html.ActionLink(doc.FileName, "DownloadDocument", new { id = doc.UserDocumentId }, new { @class = "btn btn-link btn-xs", style="display:block; text-align:left; padding:0;" })
                }
            }
            else
            {
                <span class="text-muted">No Files</span>
            }
        </td>
        <td>
            @Html.ActionLink("Edit", "Edit", new { id=item.UserId }) |
            @Html.ActionLink("Details", "Details", new { id=item.UserId }) |
            <a href="javascript:void(0)" onclick="deleteUser(@item.UserId)" class="text-danger">Delete</a>
        </td>
    </tr>
}
